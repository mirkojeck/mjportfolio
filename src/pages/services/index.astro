---
import { getCollection } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import { getSiteSettings, sortByOrder } from '@lib/siteContent';

const site = getSiteSettings();
const services = sortByOrder(await getCollection('services'), 'asc');
---

<BaseLayout title={`Services | ${site.brand.name}`} description={site.seo.description}>
  <div class="mil-inner-banner">
    <div class="mil-banner-content mil-up">
      <div class="mil-animation-frame">
        <div class="mil-animation mil-position-4 mil-dark mil-scale" data-value-1="6" data-value-2="1.4"></div>
      </div>
      <div class="container">
        <ul class="mil-breadcrumbs mil-mb-60">
          <li><a href="/">Homepage</a></li>
          <li><a href="/services/">Services</a></li>
        </ul>
        <h1 class="mil-mb-60">This is <span class="mil-thin">what</span><br /> we do <span class="mil-thin">best</span></h1>
        <a href="#services" class="mil-link mil-dark mil-arrow-place mil-down-arrow">
          <span>Our services</span>
        </a>
      </div>
    </div>
  </div>

  <section id="services">
    <div class="container mil-p-120-90">
      <div class="row mil-services-grid m-0">
        {services.map((service) => (
          <div class="col-md-6 col-lg-3 mil-services-grid-item p-0">
            <a href={`/services/${service.id}/`} class="mil-service-card-sm mil-up">
              <h5 class="mil-muted mil-mb-30">{service.data.title}</h5>
              <p class="mil-light-soft mil-mb-30">{service.data.summary}</p>
              <div class="mil-button mil-icon-button-sm mil-arrow-place"></div>
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="mil-soft-bg">
    <div class="container mil-p-120-120">
      <div class="row">
        <div class="col-lg-10">
          <span class="mil-suptitle mil-suptitle-right mil-suptitle-dark mil-up">Looking to make your mark? We'll help you turn <br /> your project into a success story.</span>
        </div>
      </div>
      <div class="mil-center">
        <h2 class="mil-up mil-mb-60">Ready to bring your <span class="mil-thin">ideas to</span> life? <br /> We're <span class="mil-thin">here to help</span></h2>
        <div class="mil-up"><a href="/contact/" class="mil-button mil-arrow-place"><span>Contact us</span></a></div>
      </div>
    </div>
  </section>
</BaseLayout>
