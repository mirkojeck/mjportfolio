<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Mirko Portfolio Admin</title>
    <link rel="stylesheet" href="/mj-admin/admin.css" />
  </head>
  <body>
    <script is:inline>
      (function () {
        if (window.location.pathname === '/mj-admin') {
          window.location.replace('/mj-admin/' + window.location.hash);
        }
      })();
    </script>
    <script is:inline>
      (function () {
        var MAX_UPLOAD_SIZE = 2 * 1024 * 1024;
        var ALLOWED_EXTENSIONS = /\.(jpe?g|png|webp|svg)$/i;

        function validateUploadFiles(event) {
          var input = event.target;
          if (!input || input.type !== 'file' || !input.files || !input.files.length) return;

          for (var i = 0; i < input.files.length; i += 1) {
            var file = input.files[i];
            var validType = ALLOWED_EXTENSIONS.test(file.name || '');
            var validSize = file.size <= MAX_UPLOAD_SIZE;

            if (!validType || !validSize) {
              input.value = '';
              window.alert('Images must be JPG, JPEG, PNG, WebP, or SVG and below 2MB.');
              return;
            }
          }
        }

        // Decap's Git media library has no schema-level file-size limit, so this is a best-effort browser guard.
        document.addEventListener('change', validateUploadFiles, true);
      })();
    </script>
    <script is:inline>
      (function () {
        var FEATURE = 'unload *';

        function patchIframe(iframe) {
          if (!iframe) return;
          var allow = iframe.getAttribute('allow') || '';
          if (allow.indexOf('unload') !== -1) return;
          var next = allow ? allow + '; ' + FEATURE : FEATURE;
          iframe.setAttribute('allow', next);
        }

        function patchAll() {
          var frames = document.querySelectorAll('iframe');
          for (var i = 0; i < frames.length; i += 1) {
            patchIframe(frames[i]);
          }
        }

        var observer = new MutationObserver(function (mutations) {
          for (var i = 0; i < mutations.length; i += 1) {
            var mutation = mutations[i];
            for (var j = 0; j < mutation.addedNodes.length; j += 1) {
              var node = mutation.addedNodes[j];
              if (!node || node.nodeType !== 1) continue;
              if (node.tagName === 'IFRAME') {
                patchIframe(node);
              }
              if (node.querySelectorAll) {
                var nested = node.querySelectorAll('iframe');
                for (var k = 0; k < nested.length; k += 1) {
                  patchIframe(nested[k]);
                }
              }
            }
          }
        });

        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', patchAll, { once: true });
        } else {
          patchAll();
        }

        observer.observe(document.documentElement, { childList: true, subtree: true });
      })();
    </script>
    <script is:inline src="https://unpkg.com/decap-cms@^3.0.0/dist/decap-cms.js"></script>
    <script is:inline>
      console.log('MJ ADMIN INDEX FILE LOADED v999');
    </script>
    <script is:inline>
      (function () {
        var preview = document.createElement('script');
        preview.src = '/mj-admin/preview.js?v=999';
        preview.onload = function () {
          console.log('MJ ADMIN PREVIEW SCRIPT ONLOAD v999');
        };
        preview.onerror = function () {
          console.error('MJ ADMIN PREVIEW SCRIPT ERROR v999');
        };
        document.body.appendChild(preview);
      })();
    </script>
    <script is:inline>
      (function () {
        function ensureCredit() {
          if (document.querySelector('.mj-admin-credit')) return;
          var credit = document.createElement('div');
          credit.className = 'mj-admin-credit';
          credit.innerHTML = 'Made with <span aria-label="love">&hearts;</span> by <a href="https://www.dxbmark.com" target="_blank" rel="noopener noreferrer">DXBMARK LLC</a>';
          document.body.appendChild(credit);
        }

        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', ensureCredit, { once: true });
        } else {
          ensureCredit();
        }
      })();
    </script>
  </body>
</html>
