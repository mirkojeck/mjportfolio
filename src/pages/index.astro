---
import { getCollection } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import ProjectCard from '@components/ProjectCard.astro';
import { getHomeSettings, getSiteSettings, sortByOrder } from '@lib/siteContent';

const site = getSiteSettings();
const home = getHomeSettings();
const allProjects = sortByOrder(await getCollection('projects'), site.projects.sortDirection);
const allGalleries = sortByOrder(await getCollection('posts'), 'desc');
const featuredProjects = allProjects
  .filter((project) => project.data.isFeatured)
  .slice(0, home.featuredProjects.limit || site.projects.featuredLimit);
const reviews = home.reviews.items.length > 0 ? home.reviews.items : [];
const featuredGalleries = allGalleries.filter((gallery) => gallery.data.isFeatured);
const homeGallerySource = featuredGalleries.length > 0 ? featuredGalleries : allGalleries;
const homeGalleryItems = homeGallerySource.length > 0
  ? homeGallerySource.slice(0, 6).map((gallery) => ({
      title: gallery.data.title,
      image: gallery.data.cover,
      href: `/blog/${gallery.id}/`,
      excerpt: gallery.data.excerpt,
    }))
  : home.blogPreview.items;
---

<BaseLayout title={site.seo.title} description={site.seo.description} image={site.seo.image}>
  <section class="mil-banner mil-dark-bg">
    <div class="mi-invert-fix">
      <div class="mil-animation-frame">
        <div class="mil-animation mil-position-1 mil-scale" data-value-1="7" data-value-2="1.6"></div>
        <div class="mil-animation mil-position-2 mil-scale" data-value-1="4" data-value-2="1"></div>
        <div class="mil-animation mil-position-3 mil-scale" data-value-1="1.2" data-value-2=".1"></div>
      </div>
      <div class="mil-gradient"></div>
      <div class="container">
        <div class="mil-banner-content mil-up">
          <h1 class="mil-muted mil-mb-60">
            {home.hero.titlePart1} <span class="mil-thin">{home.hero.titleThin1}</span><br />
            {home.hero.titlePart2} <span class="mil-thin">{home.hero.titleThin2}</span>
          </h1>
          <div class="row">
            <div class="col-md-7 col-lg-5">
              <p class="mil-light-soft mil-mb-60">{home.hero.description}</p>
            </div>
          </div>
          <a href={home.hero.ctaHref} class="mil-button mil-arrow-place mil-btn-space">
            <span>{home.hero.ctaLabel}</span>
          </a>
          <a href={home.hero.secondaryCtaHref} class="mil-link mil-muted mil-arrow-place">
            <span>{home.hero.secondaryCtaLabel}</span>
          </a>
          <div class="mil-circle-text">
            <svg version="1.1" xmlns="http://www.w3.org/2000/svg" x="0px" y="0px" viewBox="0 0 300 300" class="mil-ct-svg mil-rotate" data-value="360">
              <defs>
                <path id="circlePath" d="M 150, 150 m -60, 0 a 60,60 0 0,1 120,0 a 60,60 0 0,1 -120,0 " />
              </defs>
              <circle cx="150" cy="100" r="75" fill="none"></circle>
              <g>
                <use href="#circlePath" fill="none"></use>
                <text style="letter-spacing: 6.5px">
                  <textPath href="#circlePath">Scroll down - Scroll down - </textPath>
                </text>
              </g>
            </svg>
            <a href="#about" class="mil-button mil-arrow-place mil-icon-button mil-arrow-down"></a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="about">
    <div class="container mil-p-120-30">
      <div class="row justify-content-between align-items-center">
        <div class="col-lg-6 col-xl-5">
          <div class="mil-mb-90">
            <h2 class="mil-up mil-mb-60">{home.about.titlePart1} <br />{home.about.titlePart2} <span class="mil-thin">{home.about.titleThin}</span></h2>
            {home.about.paragraphs.map((paragraph, index) => (
              <p class={`mil-up ${index === home.about.paragraphs.length - 1 ? 'mil-mb-60' : 'mil-mb-30'}`}>{paragraph}</p>
            ))}
            <div class="mil-about-quote">
              <div class="mil-avatar mil-up">
                <img src={home.about.quoteImage} alt="Founder" />
              </div>
              <h6 class="mil-quote mil-up">{home.about.quote}</h6>
            </div>
          </div>
        </div>
        <div class="col-lg-5">
          <div class="mil-about-photo mil-mb-90">
            <div class="mil-lines-place"></div>
            <div class="mil-up mil-img-frame" style="padding-bottom: 160%;">
              <img src={home.about.image} alt="Studio" class="mil-scale" data-value-1="1" data-value-2="1.2" />
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="mil-dark-bg">
    <div class="mi-invert-fix">
      <div class="mil-animation-frame">
        <div class="mil-animation mil-position-1 mil-scale" data-value-1="2.4" data-value-2="1.4" style="top: 300px; right: -100px"></div>
        <div class="mil-animation mil-position-2 mil-scale" data-value-1="2" data-value-2="1" style="left: 150px"></div>
      </div>
      <div class="container mil-p-120-0">
        <div class="mil-mb-120">
          <div class="row">
            <div class="col-lg-10">
              <span class="mil-suptitle mil-light-soft mil-suptitle-right mil-up">{home.servicesPreview.eyebrow}</span>
            </div>
          </div>
          <div class="mil-complex-text justify-content-center mil-up mil-mb-15">
            <span class="mil-text-image"><img src={home.servicesPreview.image} alt="team" /></span>
            <h2 class="mil-h1 mil-muted mil-center">{home.servicesPreview.titleLine1}</h2>
          </div>
          <div class="mil-complex-text justify-content-center mil-up">
            <h2 class="mil-h1 mil-muted mil-center">{home.servicesPreview.titleLine2}</h2>
            <a href={home.servicesPreview.ctaHref} class="mil-services-button mil-button mil-arrow-place"><span>{home.servicesPreview.ctaLabel}</span></a>
          </div>
        </div>
        <div class="row mil-services-grid m-0">
          {home.servicesPreview.items.map((item) => (
            <div class="col-md-6 col-lg-3 mil-services-grid-item p-0">
              <a href={item.href} class="mil-service-card-sm mil-up">
                <h5 class="mil-muted mil-mb-30">{item.title}</h5>
                <p class="mil-light-soft mil-mb-30">{item.summary}</p>
                <div class="mil-button mil-icon-button-sm mil-arrow-place"></div>
              </a>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section id="featured-projects">
    <div class="container mil-portfolio mil-p-120-60">
      <div class="row align-items-center mil-mb-30">
        <div class="col-lg-6 mil-mb-30">
          <h3 class="mil-up">{home.featuredProjects.heading}</h3>
        </div>
        <div class="col-lg-6 mil-mb-30">
          <div class="mil-adaptive-right mil-up">
            <a href="/portfolio/" class="mil-link mil-dark mil-arrow-place">
              <span>View all</span>
            </a>
          </div>
        </div>
      </div>
      <div class="row justify-content-between align-items-center">
        {featuredProjects.map((project) => (
          <div class={project.data.order % 3 === 1 ? 'col-lg-5' : 'col-lg-6'}>
            <ProjectCard project={project} />
          </div>
        ))}
      </div>
    </div>
  </section>

  <section>
    <div class="container mil-p-120-30">
      <div class="row justify-content-between align-items-center">
        <div class="col-lg-5 col-xl-4">
          <div class="mil-mb-90">
            <h2 class="mil-up mil-mb-60">{home.teamPreview.titlePart1} <br />{home.teamPreview.titlePart2}</h2>
            {home.teamPreview.paragraphs.map((paragraph, index) => (
              <p class={`mil-up ${index === home.teamPreview.paragraphs.length - 1 ? 'mil-mb-60' : 'mil-mb-30'}`}>{paragraph}</p>
            ))}
            <div class="mil-up"><a href={home.teamPreview.ctaHref} class="mil-button mil-arrow-place mil-mb-60"><span>{home.teamPreview.ctaLabel}</span></a></div>
            <h4 class="mil-up"><span class="mil-thin">{home.teamPreview.closingLine1}</span> <br /><span class="mil-thin">{home.teamPreview.closingLine2}</span></h4>
          </div>
        </div>
        <div class="col-lg-6">
          <div class="mil-team-list">
            <div class="mil-lines-place"></div>
            <div class="row mil-mb-60">
              <div class="col-sm-6">
                {home.teamPreview.members.slice(0, 2).map((member) => (
                  <div class="mil-team-card mil-up mil-mb-30">
                    <img src={member.image} alt={member.name} />
                    <div class="mil-description">
                      <div class="mil-secrc-text">
                        <h5 class="mil-muted mil-mb-5"><a href={member.href}>{member.name}</a></h5>
                        <p class="mil-link mil-light-soft mil-mb-10">{member.role}</p>
                      </div>
                    </div>
                  </div>
                ))}
              </div>
              <div class="col-sm-6">
                <p class="mil-mobile-hidden mil-text-sm mil-mb-30" style="height: 30px;"><span class="mil-accent">*</span> {home.teamPreview.note}</p>
                {home.teamPreview.members.slice(2, 4).map((member) => (
                  <div class="mil-team-card mil-up mil-mb-30">
                    <img src={member.image} alt={member.name} />
                    <div class="mil-description">
                      <div class="mil-secrc-text">
                        <h5 class="mil-muted mil-mb-5"><a href={member.href}>{member.name}</a></h5>
                        <p class="mil-link mil-light-soft mil-mb-10">{member.role}</p>
                      </div>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="mil-soft-bg">
    <div class="container mil-p-120-120">
      <div class="row">
        <div class="col-lg-10">
          <span class="mil-suptitle mil-suptitle-right mil-suptitle-dark mil-up">{home.reviews.eyebrow}</span>
        </div>
      </div>
      <h2 class="mil-center mil-up mil-mb-60">{home.reviews.titlePart1}: <br /><span class="mil-thin">{home.reviews.titlePart2}</span></h2>
      <div class="mil-revi-pagination mil-up mil-mb-60"></div>
      <div class="row mil-relative justify-content-center">
        <div class="col-lg-8">
          <div class="mil-slider-nav mil-soft mil-reviews-nav mil-up">
            <div class="mil-slider-arrow mil-prev mil-revi-prev mil-arrow-place"></div>
            <div class="mil-slider-arrow mil-revi-next mil-arrow-place"></div>
          </div>
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 48 48" class="mil-quote-icon mil-up">
            <path d="M 13.5 10 A 8.5 8.5 0 0 0 13.5 27 A 8.5 8.5 0 0 0 18.291016 25.519531 C 17.422273 29.222843 15.877848 31.803343 14.357422 33.589844 C 12.068414 36.279429 9.9433594 37.107422 9.9433594 37.107422 A 1.50015 1.50015 0 1 0 11.056641 39.892578 C 11.056641 39.892578 13.931586 38.720571 16.642578 35.535156 C 19.35357 32.349741 22 27.072581 22 19 A 1.50015 1.50015 0 0 0 21.984375 18.78125 A 8.5 8.5 0 0 0 13.5 10 z M 34.5 10 A 8.5 8.5 0 0 0 34.5 27 A 8.5 8.5 0 0 0 39.291016 25.519531 C 38.422273 29.222843 36.877848 31.803343 35.357422 33.589844 C 33.068414 36.279429 30.943359 37.107422 30.943359 37.107422 A 1.50015 1.50015 0 1 0 32.056641 39.892578 C 32.056641 39.892578 34.931586 38.720571 37.642578 35.535156 C 40.35357 32.349741 43 27.072581 43 19 A 1.50015 1.50015 0 0 0 42.984375 18.78125 A 8.5 8.5 0 0 0 34.5 10 z" fill="#000000"></path>
          </svg>
          <div class="swiper-container mil-reviews-slider">
            <div class="swiper-wrapper">
              {[...reviews, ...reviews, ...reviews].map((review) => (
                <div class="swiper-slide">
                  <div class="mil-review-frame mil-center" data-swiper-parallax="-200" data-swiper-parallax-opacity="0">
                    <h5 class="mil-up mil-mb-10">{review.name}</h5>
                    <p class="mil-mb-5 mil-upper mil-up mil-mb-30">{review.company}</p>
                    <p class="mil-text-xl mil-up">{review.quote}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="mil-soft-bg">
    <div class="container mil-p-0-120">
      <div class="swiper-container mil-infinite-show mil-up">
        <div class="swiper-wrapper">
          {home.partners.map((partner) => (
            <div class="swiper-slide">
              <a href={partner.href} class="mil-partner-frame" style={`width: ${partner.width};`}><img src={partner.image} alt="logo" /></a>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>

  <section>
    <div class="container mil-p-120-90">
      <div class="mj-home-gallery-heading mil-center mil-mb-60">
        <h3 class="mil-up">{home.blogPreview.heading}</h3>
        <p class="mil-up">{home.blogPreview.description || 'A visual collection of recent works, each piece crafted with intention, emotion, and style.'}</p>
      </div>
      <div class="mj-home-gallery mil-up">
        {homeGalleryItems.map((item) => (
          <a href={item.href} class="mj-home-gallery__item" aria-label={item.title}>
            <img src={item.image} alt={item.title} />
            <span>{item.title}</span>
          </a>
        ))}
      </div>
      <div class="mj-home-gallery-action mil-center mil-up">
        <a href={home.blogPreview.ctaHref} class="mil-link mil-dark mil-arrow-place">
          <span>{home.blogPreview.ctaLabel}</span>
        </a>
      </div>
    </div>
  </section>

  <section class="mil-soft-bg">
    <div class="container mil-p-120-120">
      <div class="row">
        <div class="col-lg-10">
          <span class="mil-suptitle mil-suptitle-right mil-suptitle-dark mil-up">{home.callToAction.eyebrow}</span>
        </div>
      </div>
      <div class="mil-center">
        <h2 class="mil-up mil-mb-60">{home.callToAction.title}</h2>
        <div class="mil-up"><a href={home.callToAction.ctaHref} class="mil-button mil-arrow-place"><span>{home.callToAction.ctaLabel}</span></a></div>
      </div>
    </div>
  </section>
</BaseLayout>
