---
import { getCollection, render } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import ProjectDetailLayout from '@components/ProjectDetailLayout.astro';
import { getSiteSettings, sortByOrder } from '@lib/siteContent';

export async function getStaticPaths() {
  const projects = await getCollection('projects');

  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const site = getSiteSettings();
const projects = sortByOrder(await getCollection('projects'), site.projects.sortDirection);
const currentIndex = projects.findIndex((item) => item.id === project.id);
const previousProject = currentIndex > 0 ? projects[currentIndex - 1] : undefined;
const nextProject = currentIndex < projects.length - 1 ? projects[currentIndex + 1] : undefined;
const { Content } = await render(project);
const title = project.data.seoTitle ?? `${project.data.title} | ${site.brand.name}`;
const description = project.data.seoDescription ?? project.data.summary;
---

<BaseLayout title={title} description={description} image={project.data.cover}>
  <div class="mil-inner-banner">
    <div class="mil-banner-content mil-up">
      <div class="mil-animation-frame">
        <div class="mil-animation mil-position-4 mil-dark mil-scale" data-value-1="6" data-value-2="1.4"></div>
      </div>
      <div class="container">
        <ul class="mil-breadcrumbs mil-mb-60">
          <li><a href="/">Homepage</a></li>
          <li><a href="/portfolio/">Portfolio</a></li>
          <li><a href={`/projects/${project.id}/`}>Project</a></li>
        </ul>
        <h1 class="mil-mb-60">{project.data.title}</h1>
        <a href="#project" class="mil-link mil-dark mil-arrow-place mil-down-arrow">
          <span>Read more</span>
        </a>
      </div>
    </div>
  </div>

  <ProjectDetailLayout project={project} Content={Content} previousProject={previousProject} nextProject={nextProject} />

  <section class="mil-soft-bg">
    <div class="container mil-p-120-120">
      <div class="row">
        <div class="col-lg-10">
          <span class="mil-suptitle mil-suptitle-right mil-suptitle-dark mil-up">Looking to make your mark? We'll help you turn <br /> your project into a success story.</span>
        </div>
      </div>
      <div class="mil-center">
        <h2 class="mil-up mil-mb-60">Ready to bring your <span class="mil-thin">ideas to</span> life? <br /> We're <span class="mil-thin">here to help</span></h2>
        <div class="mil-up"><a href="/contact/" class="mil-button mil-arrow-place"><span>Contact us</span></a></div>
      </div>
    </div>
  </section>
</BaseLayout>
