---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import { getSiteSettings, sortByOrder } from '@lib/siteContent';

const site = getSiteSettings();
const posts = sortByOrder(await getCollection('posts'), 'desc');
const listingLayout = site.gallery?.listingLayout ?? 'grid';
const getGalleryImages = (post: CollectionEntry<'posts'>) => post.data.gallery.length > 0 ? post.data.gallery : [post.data.cover];
const getHoverEffect = (post: CollectionEntry<'posts'>) => post.data.hoverEffect || site.gallery?.defaultHoverEffect || 'zoom';
---

<BaseLayout title={`Gallery | ${site.brand.name}`} description={site.seo.description}>
  <div class="mil-inner-banner">
    <div class="mil-banner-content mil-up">
      <div class="mil-animation-frame">
        <div class="mil-animation mil-position-4 mil-dark mil-scale" data-value-1="6" data-value-2="1.4"></div>
      </div>
      <div class="container">
        <ul class="mil-breadcrumbs mil-mb-60">
          <li><a href="/">Homepage</a></li>
          <li><a href="/blog/">Gallery</a></li>
        </ul>
        <h1 class="mil-mb-60">Image <span class="mil-thin">gallery</span></h1>
        <a href="#blog" class="mil-link mil-dark mil-arrow-place mil-down-arrow">
          <span>View gallery</span>
        </a>
      </div>
    </div>
  </div>

  <section id="blog">
    {listingLayout === 'portfolioSlider' ? (
      <section class="mil-portfolio-slider-frame mj-gallery-slider-frame">
        <div class="mil-animation-frame">
          <div class="mil-animation mil-position-4 mil-dark mil-scale" data-value-1="1" data-value-2="2" style="top: -60px; right: -4px;"></div>
        </div>
        <div class="container">
          <div class="row align-items-end">
            <div class="col-lg-9">
              <div class="swiper-container mil-portfolio-slider mil-up">
                <div class="swiper-wrapper">
                  {posts.map((post) => (
                    <div class="swiper-slide">
                      <div class="mil-portfolio-item mil-slider-item" data-swiper-parallax="-30">
                        <div class="mil-cover-frame mil-drag">
                          <div class="mil-cover" data-swiper-parallax-scale="1.3">
                            <img src={post.data.cover} alt={post.data.title} />
                          </div>
                        </div>
                        <div class="mil-descr" data-swiper-parallax-x="104%" data-swiper-parallax-opacity="0">
                          <div class="mil-descr-text" data-swiper-parallax-y="100%" data-swiper-parallax-opacity="0">
                            <div class="mil-labels mil-mb-15">
                              <div class="mil-label mil-upper mil-accent">{post.data.tags[0] ?? 'Gallery'}</div>
                              <div class="mil-label mil-upper">{post.data.date.toLocaleDateString('en', { month: 'short', day: '2-digit', year: 'numeric' })}</div>
                            </div>
                            <h5>{post.data.title}</h5>
                          </div>
                          <div data-swiper-parallax-y="120" data-swiper-parallax-opacity="0">
                            <a href={`/blog/${post.id}/`} class="mil-button mil-arrow-place"><span>View Gallery</span></a>
                          </div>
                        </div>
                      </div>
                    </div>
                  ))}
                </div>
              </div>
            </div>
            <div class="col-lg-3 mil-relative">
              <div class="mil-portfolio-nav">
                <div class="mil-portfolio-btns-frame">
                  <div class="swiper-portfolio-pagination"></div>
                  <div class="mil-slider-nav">
                    <div class="mil-slider-arrow mil-prev mil-portfolio-prev mil-arrow-place"></div>
                    <div class="mil-slider-arrow mil-portfolio-next mil-arrow-place"></div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>
    ) : (
      <div class="container mil-p-120-60">
        <div class="row">
          {posts.map((post) => (
            <div class="col-lg-6">
              <a href={`/blog/${post.id}/`} class={`mj-gallery-card mj-gallery-card--${getHoverEffect(post)} mil-mb-60`}>
                <div class="mj-gallery-card__image mil-up">
                  <img src={post.data.cover} alt={post.data.title} />
                </div>
                <div class="mj-gallery-card__content">
                  <div class="mil-labels mil-up mil-mb-30">
                    <div class="mil-label mil-upper mil-accent">{post.data.tags[0] ?? 'Gallery'}</div>
                    <div class="mil-label mil-upper">{getGalleryImages(post).length} images</div>
                  </div>
                  <h4 class="mil-up mil-mb-20">{post.data.title}</h4>
                  <p class="mil-post-text mil-up mil-mb-30">{post.data.excerpt}</p>
                  <div class="mil-link mil-dark mil-arrow-place mil-up"><span>View gallery</span></div>
                </div>
              </a>
            </div>
          ))}
        </div>
      </div>
    )}
  </section>
</BaseLayout>
