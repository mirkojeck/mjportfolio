---
import { getCollection } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import PortfolioLayout from '@components/PortfolioLayout.astro';
import { getDefaultPortfolioLayout, getPageCopy, getSiteSettings, sortByOrder } from '@lib/siteContent';

const site = getSiteSettings();
const pageCopy = getPageCopy();
const projects = sortByOrder(await getCollection('projects'), site.projects.sortDirection);
const portfolioLayout = getDefaultPortfolioLayout(site);
---

<BaseLayout title={`Portfolio | ${site.brand.name}`} description={site.seo.description}>
  <div class="mil-inner-banner">
    <div class="mil-banner-content mil-up">
      <div class="mil-animation-frame">
        <div class="mil-animation mil-position-4 mil-dark mil-scale" data-value-1="6" data-value-2="1.4"></div>
      </div>
      <div class="container">
        <ul class="mil-breadcrumbs mil-mb-60">
          <li><a href="/">Homepage</a></li>
          <li><a href="/portfolio/">Portfolio</a></li>
        </ul>
        <h1 class="mil-mb-60">{pageCopy.portfolio.hero.titleLine1} <br /> {pageCopy.portfolio.hero.titleLine2} <span class="mil-thin">{pageCopy.portfolio.hero.titleLine3}</span></h1>
        <a href="#portfolio" class="mil-link mil-dark mil-arrow-place mil-down-arrow">
          <span>{pageCopy.portfolio.hero.downArrowLabel}</span>
        </a>
      </div>
    </div>
  </div>

  <PortfolioLayout projects={projects} layout={portfolioLayout} />

  <section class="mil-soft-bg">
    <div class="container mil-p-120-120">
      <div class="row">
        <div class="col-lg-10">
          <span class="mil-suptitle mil-suptitle-right mil-suptitle-dark mil-up">{pageCopy.portfolio.cta.eyebrow}</span>
        </div>
      </div>
      <div class="mil-center">
        <h2 class="mil-up mil-mb-60">{pageCopy.portfolio.cta.titleLine1} <span class="mil-thin">{pageCopy.portfolio.cta.titleLine2}</span> {pageCopy.portfolio.cta.titleLine3} <br /> {pageCopy.portfolio.cta.titleLine4} <span class="mil-thin">{pageCopy.portfolio.cta.titleLine5}</span></h2>
        <div class="mil-up"><a href="/contact/" class="mil-button mil-arrow-place"><span>{pageCopy.portfolio.cta.buttonLabel}</span></a></div>
      </div>
    </div>
  </section>
</BaseLayout>
