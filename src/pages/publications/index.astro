---
import { getCollection } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import { getPageCopy, getSiteSettings, sortByOrder } from '@lib/siteContent';

const site = getSiteSettings();
const pageCopy = getPageCopy();
const publications = sortByOrder(await getCollection('publications'), 'desc');
---

<BaseLayout title={`Publications | ${site.brand.name}`} description={site.seo.description}>
  <div class="mil-inner-banner">
    <div class="mil-banner-content mil-up">
      <div class="mil-animation-frame">
        <div class="mil-animation mil-position-4 mil-dark mil-scale" data-value-1="6" data-value-2="1.4"></div>
      </div>
      <div class="container">
        <ul class="mil-breadcrumbs mil-mb-60"><li><a href="/">Homepage</a></li><li><a href="/publications/">Publications</a></li></ul>
        <h1 class="mil-mb-60">{pageCopy.publications.hero.titleLine1} <span class="mil-thin">{pageCopy.publications.hero.titleLine2}</span></h1>
        <a href="#publications" class="mil-link mil-dark mil-arrow-place mil-down-arrow"><span>{pageCopy.publications.hero.downArrowLabel}</span></a>
      </div>
    </div>
  </div>

  <section id="publications">
    <div class="container mil-p-120-60">
      <div class="row">
        {publications.map((publication) => (
          <div class="col-lg-6">
            <a href={`/publications/${publication.id}/`} class="mil-blog-card mil-mb-60 mil-up">
              <div class="mil-cover-frame mil-mb-30">
                <img src={publication.data.cover} alt={publication.data.title} />
              </div>
              <div class="mil-post-descr">
                <div class="mil-labels mil-mb-30">
                  <div class="mil-label mil-upper mil-accent">{publication.data.tags[0] ?? 'Publication'}</div>
                  <div class="mil-label mil-upper">{publication.data.date.toLocaleDateString('en', { month: 'short', day: '2-digit', year: 'numeric' })}</div>
                </div>
                <h4 class="mil-mb-30">{publication.data.title}</h4>
                <p class="mil-post-text">{publication.data.excerpt}</p>
                <div class="mil-link mil-dark mil-arrow-place mil-mt-20"><span>{pageCopy.publications.listing.readMoreLabel}</span></div>
              </div>
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
