---
import { formatProjectDate } from '@lib/siteContent';

const { project } = Astro.props;
const label = project.data.services?.[0] ?? project.data.client;
const displayDate = formatProjectDate(project.data.date, project.data.year);
const frameClass = project.data.order % 3 === 1 ? 'mil-vert' : 'mil-hori';
const parallaxClass = frameClass === 'mil-hori' ? ' mil-parallax' : '';
---

<a href={`/projects/${project.id}/`} class={`mil-portfolio-item mil-more${parallaxClass} mil-mb-60`} data-value-1="60" data-value-2="-60">
  <div class={`mil-cover-frame ${frameClass} mil-up`}>
    <div class="mil-cover">
      <img src={project.data.cover} alt={project.data.title} />
    </div>
  </div>
  <div class="mil-descr">
    <div class="mil-labels mil-up mil-mb-15">
      <div class="mil-label mil-upper mil-accent">{label}</div>
      <div class="mil-label mil-upper">{displayDate}</div>
    </div>
    <h4 class="mil-up">{project.data.title}</h4>
  </div>
</a>
